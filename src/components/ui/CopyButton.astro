---
interface Props {
  targetId: string;
  class?: string;
}
const { targetId, class: className = '' } = Astro.props;
---
<button
  type="button"
  data-copy-target={targetId}
  class={`h-10 px-[18px] bg-primary text-onPrimary font-medium text-sm rounded-md cursor-pointer hover:bg-primaryActive active:scale-98 transition-all inline-flex items-center justify-center gap-1.5 ${className}`}
>
  <!-- Copy Icon -->
  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4 copy-icon">
    <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 17.25v3.375c0 .621-.504 1.125-1.125 1.125h-9.75a1.125 1.125 0 01-1.125-1.125V7.875c0-.621.504-1.125 1.125-1.125H5.25m11.9-3.664A2.251 2.251 0 0015 2.25h-3a2.251 2.251 0 00-2.15 1.586m5.8 0c.065.21.1.433.1.664v.75h-6V4.5c0-.231.035-.454.1-.664M6.75 7.375c0-.621.504-1.125 1.125-1.125h9.75c.621 0 1.125.504 1.125 1.125v.75m-12 9v-9m12 9v-9" />
  </svg>
  <!-- Success checkmark icon (hidden by default) -->
  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4 success-icon hidden">
    <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
  </svg>
  <span class="btn-text text-xs font-semibold">Copy to Clipboard</span>
</button>

<script>
  function setupCopyButtons() {
    const buttons = document.querySelectorAll('[data-copy-target]');
    buttons.forEach(button => {
      if (button.getAttribute('data-listener-attached') === 'true') return;
      
      button.addEventListener('click', async () => {
        const targetId = button.getAttribute('data-copy-target');
        if (!targetId) return;

        const target = document.getElementById(targetId) as HTMLTextAreaElement | HTMLInputElement | HTMLDivElement | null;
        if (!target) return;

        let textToCopy = '';
        if (target instanceof HTMLTextAreaElement || target instanceof HTMLInputElement) {
          textToCopy = target.value;
        } else {
          textToCopy = target.innerText;
        }

        if (!textToCopy) return;

        try {
          await navigator.clipboard.writeText(textToCopy);
          
          const copyIcon = button.querySelector('.copy-icon');
          const successIcon = button.querySelector('.success-icon');
          const btnText = button.querySelector('.btn-text');

          if (copyIcon && successIcon && btnText) {
            copyIcon.classList.add('hidden');
            successIcon.classList.remove('hidden');
            const originalText = btnText.textContent;
            btnText.textContent = 'Copied!';
            
            setTimeout(() => {
              copyIcon.classList.remove('hidden');
              successIcon.classList.add('hidden');
              btnText.textContent = originalText;
            }, 2000);
          }
        } catch (err) {
          console.error('Failed to copy text: ', err);
        }
      });
      
      button.setAttribute('data-listener-attached', 'true');
    });
  }

  setupCopyButtons();
  document.addEventListener('astro:page-load', setupCopyButtons);
</script>
